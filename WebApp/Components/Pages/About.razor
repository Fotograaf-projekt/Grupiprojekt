@page "/about"
@inject PhotographerService PhotographerService

<PageTitle>Minust</PageTitle>

<div class="about-wrap">
    @if (photographer is null)
    {
        <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
    }
    else
    {
        <div class="about-grid">
            <div>
                <img src="@(string.IsNullOrEmpty(photographer.ProfileImageUrl)
                            ? "https://picsum.photos/seed/portrait/700/950?grayscale"
                            : photographer.ProfileImageUrl)"
                     alt="@photographer.Name"
                     class="about-photo" />
            </div>
            <div class="about-text">
                <p class="eyebrow" style="font-size:0.7rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--muted);margin-bottom:0.5rem;">
                    Fotograaf
                </p>
                <h1>@photographer.Name</h1>
                <div class="about-divider"></div>

                @if (!string.IsNullOrEmpty(photographer.About))
                {
                    <p class="about-bio">@photographer.About</p>
                }

                <div style="margin-top:2rem;">
                    <p style="font-size:0.72rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);margin-bottom:0.75rem;">
                        Kontakt
                    </p>
                    <a href="mailto:@photographer.Email" style="color:var(--dark);border-bottom:1px solid var(--border);">
                        @photographer.Email
                    </a>
                </div>

                @if (photographer.SocialLinks?.Count > 0)
                {
                    <div style="margin-top:2rem;">
                        <SocialLinksBar Links="photographer.SocialLinks" />
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private Photographer? photographer;

    protected override async Task OnInitializedAsync()
    {
        photographer = await PhotographerService.GetMainAsync();
    }
}
