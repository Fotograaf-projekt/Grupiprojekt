@implements IDisposable
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">Fotograaf</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Avaleht
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/about">
                <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> Minust
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/services">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Teenused
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <hr class="text-light my-2" />
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin/photographer">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> Profiil
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin/services">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Teenused
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin/social-links">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Sotsiaalmeedia
                    </NavLink>
                </div>
                <hr class="text-light my-2" />
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Account/Manage">
                        <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logi välja
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <hr class="text-light my-2" />
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Logi sisse
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
