@page "/admin/social-links"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@inject PhotographerService PhotographerService

<PageTitle>Admin · Sotsiaalmeedia</PageTitle>

<h1>Sotsiaalmeedia lingid</h1>

@if (photographer is null)
{
    <p>Laen…</p>
}
else
{
    <table class="table">
        <thead><tr><th>Platvorm</th><th>URL</th><th></th></tr></thead>
        <tbody>
            @foreach (var l in links)
            {
                <tr>
                    <td><InputText class="form-control form-control-sm" @bind-Value="l.Platform" /></td>
                    <td><InputText class="form-control form-control-sm" @bind-Value="l.Url" /></td>
                    <td>
                        <button class="btn btn-sm btn-success" @onclick="() => Update(l)">Salvesta</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(l.Id)">Kustuta</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h3 class="mt-4">Lisa uus link</h3>
    <EditForm Model="newLink" OnValidSubmit="Add">
        <DataAnnotationsValidator />
        <div class="row g-2">
            <div class="col-md-3"><InputText class="form-control" placeholder="Platvorm (Instagram)" @bind-Value="newLink.Platform" /></div>
            <div class="col-md-7"><InputText class="form-control" placeholder="https://..." @bind-Value="newLink.Url" /></div>
            <div class="col-md-2"><button type="submit" class="btn btn-primary w-100">Lisa</button></div>
        </div>
    </EditForm>
    @if (!string.IsNullOrEmpty(error)) { <div class="alert alert-danger mt-3">@error</div> }
}

@code {
    private Photographer? photographer;
    private List<SocialLink> links = new();
    private SocialLink newLink = new();
    private string? error;

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        photographer = await PhotographerService.GetMainAsync();
        if (photographer is not null)
            links = await PhotographerService.SocialLinksForAsync(photographer.Id);
    }

    private async Task Add()
    {
        if (photographer is null) return;
        try
        {
            newLink.PhotographerId = photographer.Id;
            await PhotographerService.AddSocialLinkAsync(newLink);
            newLink = new();
            error = null;
            await Reload();
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task Update(SocialLink l) => await PhotographerService.UpdateSocialLinkAsync(l);

    private async Task Delete(int id)
    {
        await PhotographerService.RemoveSocialLinkAsync(id);
        await Reload();
    }
}
