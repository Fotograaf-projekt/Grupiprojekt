@implements IDisposable
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Photography</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-about-gold" aria-hidden="true"></span> Meist
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="services">
                <span class="bi bi-services-gold" aria-hidden="true"></span> Teenused
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="albums">
                <span class="bi bi-albums-gold" aria-hidden="true"></span> Albumid
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="categories">
                <span class="bi bi-categories-gold" aria-hidden="true"></span> Kategooriad
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="menu-divider"></div>
                <div class="menu-section-title">Haldus</div>

                <div class="nav-item px-3 admin-item">
                    <NavLink class="nav-link" href="admin/photographer">
                        <span class="bi bi-admin-lock" aria-hidden="true"></span> Profiil
                    </NavLink>
                </div>
                <div class="nav-item px-3 admin-item">
                    <NavLink class="nav-link" href="admin/services">
                        <span class="bi bi-admin-lock" aria-hidden="true"></span> Teenused
                    </NavLink>
                </div>
                <div class="nav-item px-3 admin-item">
                    <NavLink class="nav-link" href="admin/social-links">
                        <span class="bi bi-admin-lock" aria-hidden="true"></span> Social
                    </NavLink>
                </div>
                <div class="nav-item px-3 admin-item">
                    <NavLink class="nav-link" href="admin/albums">
                        <span class="bi bi-admin-lock" aria-hidden="true"></span> Albumid
                    </NavLink>
                </div>
                <div class="nav-item px-3 admin-item">
                    <NavLink class="nav-link" href="admin/photos">
                        <span class="bi bi-admin-lock" aria-hidden="true"></span> Fotod
                    </NavLink>
                </div>
                <div class="nav-item px-3 admin-item">
                    <NavLink class="nav-link" href="admin/categories">
                        <span class="bi bi-admin-lock" aria-hidden="true"></span> Kategooriad
                    </NavLink>
                </div>

                <div class="menu-divider"></div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-about-gold" aria-hidden="true"></span> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link w-100 text-start border-0 bg-transparent p-0">
                            <span class="bi bi-admin-lock" aria-hidden="true" style="filter: grayscale(1); opacity: 0.5;"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            
            <NotAuthorized>
                <div class="menu-divider"></div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-admin-lock" aria-hidden="true"></span> Sisselogimine
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}