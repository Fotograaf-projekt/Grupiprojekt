@page "/booking"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>Booking</PageTitle>

<h1>Book a Session</h1>

<EditForm Model="booking" OnValidSubmit="Book">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label>Name</label>
        <InputText class="form-control" @bind-Value="clientName" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <InputText class="form-control" @bind-Value="clientEmail" />
    </div>

    <div class="mb-3">
        <label>Date</label>
        <InputDate class="form-control" @bind-Value="booking.Date" />
    </div>

    <div class="mb-3">
        <label>Time</label>
        <InputText class="form-control" @bind-Value="time" placeholder="14:00" />
    </div>

    <div class="mb-3">
        <label>Message</label>
        <InputTextArea class="form-control" @bind-Value="message" />
    </div>

    <button class="btn btn-primary" type="submit">
        Broneeri
    </button>
</EditForm>

@if (saved)
{
    <p class="text-success mt-3">Booking request sent successfully.</p>
}

@code {
    private global::App.Domain.Booking booking = new()
    {
        Date = DateTime.Today,
        Status = "Pending",
        Total = 0
    };

    private string? clientName;
    private string? clientEmail;
    private string? time;
    private string? message;

    private bool saved;

    private async Task Book()
{
    saved = true;

    await Task.Delay(2000);

    Navigation.NavigateTo("/");
}
}