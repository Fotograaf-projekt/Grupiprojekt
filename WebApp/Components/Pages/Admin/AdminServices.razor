@page "/admin/services"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@inject PhotographerService PhotographerService

<PageTitle>Admin · Teenused</PageTitle>

<h1>Teenused</h1>

@if (photographer is null)
{
    <p>Laen…</p>
}
else
{
    <table class="table">
        <thead><tr><th>Nimi</th><th>Hind (€)</th><th>Kirjeldus</th><th></th></tr></thead>
        <tbody>
            @foreach (var s in services)
            {
                <tr>
                    <td><InputText class="form-control form-control-sm" @bind-Value="s.Name" /></td>
                    <td><InputNumber class="form-control form-control-sm" @bind-Value="s.Price" /></td>
                    <td><InputText class="form-control form-control-sm" @bind-Value="s.Description" /></td>
                    <td>
                        <button class="btn btn-sm btn-success" @onclick="() => UpdateRow(s)">Salvesta</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(s.Id)">Kustuta</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h3 class="mt-4">Lisa uus teenus</h3>
    <EditForm Model="newService" OnValidSubmit="Add">
        <DataAnnotationsValidator />
        <div class="row g-2">
            <div class="col-md-3"><InputText class="form-control" placeholder="Nimi" @bind-Value="newService.Name" /></div>
            <div class="col-md-2"><InputNumber class="form-control" placeholder="Hind" @bind-Value="newService.Price" /></div>
            <div class="col-md-5"><InputText class="form-control" placeholder="Kirjeldus" @bind-Value="newService.Description" /></div>
            <div class="col-md-2"><button type="submit" class="btn btn-primary w-100">Lisa</button></div>
        </div>
    </EditForm>
    @if (!string.IsNullOrEmpty(error)) { <div class="alert alert-danger mt-3">@error</div> }
}

@code {
    private Photographer? photographer;
    private List<Service> services = new();
    private Service newService = new();
    private string? error;

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        photographer = await PhotographerService.GetMainAsync();
        if (photographer is not null)
            services = await PhotographerService.ServicesForAsync(photographer.Id);
    }

    private async Task Add()
    {
        if (photographer is null) return;
        try
        {
            newService.PhotographerId = photographer.Id;
            await PhotographerService.AddServiceAsync(newService);
            newService = new();
            error = null;
            await Reload();
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task UpdateRow(Service s)
    {
        await PhotographerService.UpdateServiceAsync(s);
    }

    private async Task Delete(int id)
    {
        await PhotographerService.RemoveServiceAsync(id);
        await Reload();
    }
}
