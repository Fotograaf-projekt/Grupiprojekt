@page "/categories"
@inject AlbumService AlbumService

<PageTitle>Kategooriad</PageTitle>
<h1>Kategooriad</h1>

@if (categories.Count == 0)
{
    <p>Hetkel kategooriaid pole.</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-3">
        @foreach (var c in categories)
        {
            <div class="col">
                <a href="/categories/@c.Id" class="text-decoration-none">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@c.Name</h5>
                            <p class="card-text text-muted">@c.Description</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

@code {
    private List<Category> categories = new();

    protected override async Task OnInitializedAsync()
    {
        categories = await AlbumService.AllCategoriesAsync();
    }
}