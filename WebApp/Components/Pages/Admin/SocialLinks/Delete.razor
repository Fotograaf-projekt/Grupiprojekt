@page "/admin/social-links/delete/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@inject PhotographerService PhotographerService
@inject NavigationManager Nav

<PageTitle>Admin · Kustuta link</PageTitle>

<h1>Kustuta link</h1>

@if (model is null)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    <div class="alert alert-warning">
        Oled kindel, et tahad kustutada platvormi <strong>@model.Platform</strong> lingi?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Platvorm</dt>
        <dd class="col-sm-9">@model.Platform</dd>
        <dt class="col-sm-3">URL</dt>
        <dd class="col-sm-9"><a href="@model.Url" target="_blank">@model.Url</a></dd>
    </dl>

    <button class="btn btn-danger me-2" @onclick="Confirm">Jah, kustuta</button>
    <a href="/admin/social-links" class="btn btn-outline-secondary">Tühista</a>
}

@code {
    [Parameter] public int Id { get; set; }

    private SocialLink? model;

    protected override async Task OnInitializedAsync()
    {
        model = await PhotographerService.FindSocialLinkAsync(Id);
        if (model is null)
            Nav.NavigateTo("/admin/social-links");
    }

    private async Task Confirm()
    {
        await PhotographerService.RemoveSocialLinkAsync(Id);
        Nav.NavigateTo("/admin/social-links");
    }
}
