@page "/services"
@inject PhotographerService PhotographerService

<PageTitle>Teenused</PageTitle>

<div class="container section">
    <p class="section-title">Mida pakun</p>
    <h1 class="mb-5">Teenused</h1>

    @if (services is null)
    {
        <div class="text-center"><div class="spinner-border" role="status"></div></div>
    }
    else if (services.Count == 0)
    {
        <p style="color:var(--color-muted)">Hetkel teenuseid pole.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var s in services)
            {
                <div class="col">
                    <div class="service-card">
                        <span class="price">@s.Price.ToString("0.##") €</span>
                        <h3>@s.Name</h3>
                        <p>@s.Description</p>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Service>? services;

    protected override async Task OnInitializedAsync()
    {
        var photographer = await PhotographerService.GetMainAsync();
        if (photographer is not null)
            services = await PhotographerService.ServicesForAsync(photographer.Id);
        else
            services = new();
    }
}
