@page "/"
@inject PhotographerService PhotographerService

<PageTitle>Avaleht</PageTitle>

@if (photographer is null)
{
    <div class="hero">
        <div class="spinner-border" role="status"></div>
    </div>
}
else
{
    <div class="hero">
        @if (!string.IsNullOrEmpty(photographer.ProfileImageUrl))
        {
            <img src="@photographer.ProfileImageUrl" alt="@photographer.Name" class="hero-avatar" />
        }

        <p class="section-title">Fotograaf</p>
        <h1>@photographer.Name</h1>
        <div class="hero-divider"></div>

        @if (!string.IsNullOrEmpty(photographer.About))
        {
            <p class="text-muted" style="max-width:480px;font-size:0.95rem;">@photographer.About</p>
        }

        <SocialLinksBar Links="photographer.SocialLinks" />

        <div class="mt-4 d-flex gap-3">
            <a href="/about" class="btn btn-outline-secondary">Minust</a>
            <a href="/services" class="btn btn-primary">Teenused</a>
        </div>
    </div>
}

@code {
    private Photographer? photographer;

    protected override async Task OnInitializedAsync()
    {
        photographer = await PhotographerService.GetMainAsync();
    }
}
