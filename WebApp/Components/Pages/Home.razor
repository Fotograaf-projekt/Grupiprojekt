@page "/"
@inject PhotographerService PhotographerService

<PageTitle>Avaleht</PageTitle>

@if (photographer is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-secondary" role="status"></div>
    </div>
}
else
{
    <div class="hero text-center py-5">
        @if (!string.IsNullOrEmpty(photographer.ProfileImageUrl))
        {
            <img src="@photographer.ProfileImageUrl" alt="@photographer.Name"
                 class="rounded-circle mb-4" style="width:160px;height:160px;object-fit:cover;" />
        }
        <h1 class="display-4 fw-bold">@photographer.Name</h1>
        <p class="lead text-muted">Fotograaf</p>
        <SocialLinksBar Links="photographer.SocialLinks" />
        <div class="mt-4">
            <a href="/about" class="btn btn-outline-secondary me-2">Minust</a>
            <a href="/services" class="btn btn-dark">Teenused</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(photographer.About))
    {
        <div class="row justify-content-center mt-5">
            <div class="col-md-8">
                <p class="text-center" style="white-space:pre-wrap">@photographer.About</p>
            </div>
        </div>
    }
}

@code {
    private Photographer? photographer;

    protected override async Task OnInitializedAsync()
    {
        photographer = await PhotographerService.GetMainAsync();
    }
}
