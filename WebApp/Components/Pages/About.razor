@page "/about"
@inject PhotographerService PhotographerService

<PageTitle>Minust</PageTitle>

@if (photographer is null)
{
    <p>Laen…</p>
}
else
{
    <div class="row">
        @if (!string.IsNullOrEmpty(photographer.ProfileImageUrl))
        {
            <div class="col-md-4">
                <img src="@photographer.ProfileImageUrl" alt="@photographer.Name" class="img-fluid rounded" />
            </div>
        }
        <div class="col">
            <h1>@photographer.Name</h1>
            <p class="text-muted"><a href="mailto:@photographer.Email">@photographer.Email</a></p>
            <p style="white-space: pre-wrap">@photographer.About</p>
            <SocialLinksBar Links="photographer.SocialLinks" />
        </div>
    </div>
}

@code {
    private Photographer? photographer;

    protected override async Task OnInitializedAsync()
    {
        photographer = await PhotographerService.GetMainAsync();
    }
}
