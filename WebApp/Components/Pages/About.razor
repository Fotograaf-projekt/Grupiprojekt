@page "/about"
@inject PhotographerService PhotographerService

<PageTitle>Minust</PageTitle>

<div class="container section">
    @if (photographer is null)
    {
        <div class="text-center"><div class="spinner-border" role="status"></div></div>
    }
    else
    {
        <p class="section-title">Minust</p>
        <div class="about-grid">
            <div>
                @if (!string.IsNullOrEmpty(photographer.ProfileImageUrl))
                {
                    <img src="@photographer.ProfileImageUrl" alt="@photographer.Name" class="about-photo" />
                }
                else
                {
                    <div class="about-photo d-flex align-items-center justify-content-center"
                         style="background:var(--color-surface);color:var(--color-muted);">
                        Foto puudub
                    </div>
                }
            </div>
            <div>
                <h1 class="mb-1">@photographer.Name</h1>
                <p style="color:var(--color-muted);font-size:0.85rem;letter-spacing:0.1em;">
                    <a href="mailto:@photographer.Email">@photographer.Email</a>
                </p>
                <div class="hero-divider" style="margin:1.5rem 0;"></div>
                @if (!string.IsNullOrEmpty(photographer.About))
                {
                    <p class="about-bio">@photographer.About</p>
                }
                <div class="mt-4">
                    <SocialLinksBar Links="photographer.SocialLinks" />
                </div>
            </div>
        </div>
    }
</div>

@code {
    private Photographer? photographer;

    protected override async Task OnInitializedAsync()
    {
        photographer = await PhotographerService.GetMainAsync();
    }
}
